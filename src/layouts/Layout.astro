---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Discovery Hida — 飛騨の本物を、少人数で。' } = Astro.props;
const siteName = 'DISCOVERY HIDA';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | {siteName}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google Fonts: ピクセル系等幅フォント -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet" />
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-stone-900 text-white">
      <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-3">
          <!-- ロゴマーク（ナビ用） -->
          <svg width="36" height="41" viewBox="0 0 100 115" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- 千木（左X）：外側ビーム 右上→左下 -->
            <line x1="44" y1="4" x2="10" y2="64" stroke="white" stroke-width="12"/>
            <!-- 千木（左X）：内側ビーム 左上→右下 -->
            <line x1="30" y1="4" x2="45" y2="64" stroke="white" stroke-width="12"/>
            <!-- 千木（右X）：内側ビーム 右上→左下 -->
            <line x1="70" y1="4" x2="55" y2="64" stroke="white" stroke-width="12"/>
            <!-- 千木（右X）：外側ビーム 左上→右下 -->
            <line x1="56" y1="4" x2="90" y2="64" stroke="white" stroke-width="12"/>
            <!-- 梁1（上段・台形：上が狭く下が広い） -->
            <polygon points="24,70 76,70 80,76 20,76" fill="white"/>
            <!-- 梁2（中段・台形） -->
            <polygon points="14,81 86,81 90,89 10,89" fill="white"/>
            <!-- 梁3（下段・台形：最も長く太い） -->
            <polygon points="6,93 94,93 98,103 2,103" fill="white"/>
          </svg>
          <span class="text-sm font-bold tracking-[0.25em] uppercase">Discovery Hida</span>
        </a>
        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-8 text-sm tracking-widest uppercase">
          <a href="/" class="hover:text-stone-300 transition-colors">Home</a>
          <a href="/about-us" class="hover:text-stone-300 transition-colors">About Us</a>
          <a href="/tours" class="hover:text-stone-300 transition-colors">Tours</a>
          <a href="/faq" class="hover:text-stone-300 transition-colors">FAQ</a>
          <a href="/contact" class="bg-white text-stone-900 px-4 py-2 hover:bg-stone-200 transition-colors">Contact</a>
        </nav>
        <!-- Mobile menu button -->
        <button id="menu-btn" class="md:hidden p-2" aria-label="メニュー">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
      <!-- Mobile nav -->
      <nav id="mobile-menu" class="hidden md:hidden bg-stone-900 border-t border-stone-700">
        <div class="flex flex-col px-4 py-4 gap-4 text-sm tracking-widest uppercase">
          <a href="/" class="hover:text-stone-300 transition-colors">Home</a>
          <a href="/about-us" class="hover:text-stone-300 transition-colors">About Us</a>
          <a href="/tours" class="hover:text-stone-300 transition-colors">Tours</a>
          <a href="/faq" class="hover:text-stone-300 transition-colors">FAQ</a>
          <a href="/contact" class="hover:text-stone-300 transition-colors">Contact</a>
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-stone-900 text-stone-400 py-12 mt-20">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-start gap-8">
          <div>
            <p class="text-white font-bold tracking-widest uppercase text-sm mb-2">Discovery Hida</p>
            <p class="text-xs">飛騨の本物を、少人数で。</p>
          </div>
          <nav class="flex flex-col gap-2 text-xs tracking-widest uppercase">
            <a href="/" class="hover:text-white transition-colors">Home</a>
            <a href="/about-us" class="hover:text-white transition-colors">About Us</a>
            <a href="/tours" class="hover:text-white transition-colors">Tours</a>
            <a href="/faq" class="hover:text-white transition-colors">FAQ</a>
            <a href="/contact" class="hover:text-white transition-colors">Contact</a>
          </nav>
        </div>
        <div class="border-t border-stone-700 mt-8 pt-6 text-xs text-center">
          © {new Date().getFullYear()} Discovery Hida. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });

      // Decap CMS identity redirect
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user: unknown) => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
  </body>
</html>
