---
import Layout from '../layouts/Layout.astro';

const homeRaw = await import('../content/pages/home.md?raw');
const lines = homeRaw.default.split('\n');
let fmLines: string[] = [];
let started = false; let inFrontmatter = false;
for (const line of lines) {
  if (line.trim() === '---') {
    if (!started) { started = true; inFrontmatter = true; continue; }
    if (inFrontmatter) { inFrontmatter = false; continue; }
  }
  if (inFrontmatter) fmLines.push(line);
}

function getField(key: string): string {
  const line = fmLines.find(l => l.startsWith(key + ':'));
  if (!line) return '';
  return line.slice(key.length + 1).trim().replace(/^"(.*)"$/, '$1');
}

const hero_title = getField('hero_title');
const hero_subtitle = getField('hero_subtitle');
const feature1_title = getField('feature1_title');
const feature1_body = getField('feature1_body');
const feature2_title = getField('feature2_title');
const feature2_body = getField('feature2_body');
const feature3_title = getField('feature3_title');
const feature3_body = getField('feature3_body');
const testimonial_body = getField('testimonial_body');
const testimonial_name = getField('testimonial_name');
const testimonial_title = getField('testimonial_title');
const hero_image = getField('hero_image') || '/images/hero.jpg';

// Fetch tours
const tourFiles = import.meta.glob('../content/tours/*.md', { eager: true, query: '?raw', import: 'default' });

function parseTourFM(raw: string) {
  const ls = raw.split('\n');
  let fm: string[] = []; let s = false; let open = false;
  for (const l of ls) {
    if (l.trim() === '---') { if (!s) { s = true; open = true; continue; } if (open) { open = false; continue; } }
    if (open) fm.push(l);
  }
  const get = (k: string) => { const r = fm.find(l => l.startsWith(k+':')); return r ? r.slice(k.length+1).trim().replace(/^"(.*)"$/,'$1') : ''; };
  return { title: get('title'), summary: get('summary'), duration: get('duration'), price: get('price'), thumbnail: get('thumbnail'), order: parseInt(get('order')) || 99 };
}

const tours = Object.entries(tourFiles)
  .map(([path, raw]) => {
    const slug = path.split('/').pop()!.replace('.md', '');
    return { slug, ...parseTourFM(raw as string) };
  })
  .sort((a, b) => a.order - b.order);
---

<Layout title="Home" description="Discovery Hida — 飛騨地方の魅力を少人数制ガイド付きツアーでご紹介します">
  <!-- ヒーロー -->
  <section class="relative bg-stone-900 text-white min-h-[85vh] flex items-end justify-center pb-16 px-4">
    {hero_image && <img src={hero_image} alt="飛騨の風景" class="absolute inset-0 w-full h-full object-cover opacity-60" />}
    <div class="relative z-10 text-center max-w-3xl">
      <div class="mb-8">
        <!-- ヒーロー用ロゴマーク（大サイズ） -->
        <svg width="140" height="161" viewBox="0 0 100 115" fill="none" xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-4 opacity-95">
          <!-- 千木（左X）：外側ビーム 右上→左下 -->
          <line x1="44" y1="4" x2="10" y2="64" stroke="white" stroke-width="12"/>
          <!-- 千木（左X）：内側ビーム 左上→右下 -->
          <line x1="30" y1="4" x2="45" y2="64" stroke="white" stroke-width="12"/>
          <!-- 千木（右X）：内側ビーム 右上→左下 -->
          <line x1="70" y1="4" x2="55" y2="64" stroke="white" stroke-width="12"/>
          <!-- 千木（右X）：外側ビーム 左上→右下 -->
          <line x1="56" y1="4" x2="90" y2="64" stroke="white" stroke-width="12"/>
          <!-- 梁1（上段・台形：上が狭く下が広い） -->
          <polygon points="24,70 76,70 80,76 20,76" fill="white"/>
          <!-- 梁2（中段・台形） -->
          <polygon points="14,81 86,81 90,89 10,89" fill="white"/>
          <!-- 梁3（下段・台形：最も長く太い） -->
          <polygon points="6,93 94,93 98,103 2,103" fill="white"/>
        </svg>
        <!-- Share Tech Mono フォントでロゴテキスト -->
        <p class="text-xs uppercase text-white/70 mb-2" style="font-family:'Share Tech Mono',monospace; letter-spacing:0.6em;">DISCOVERY</p>
        <p class="text-4xl uppercase" style="font-family:'Share Tech Mono',monospace; letter-spacing:0.3em;">HIDA</p>
      </div>
      <p class="text-stone-300 leading-relaxed max-w-2xl mx-auto mb-10">{hero_subtitle}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/tours" class="bg-white text-stone-900 px-8 py-3 font-semibold tracking-wide hover:bg-stone-200 transition-colors">ツアーを見る</a>
        <a href="/contact" class="border border-white text-white px-8 py-3 font-semibold tracking-wide hover:bg-white hover:text-stone-900 transition-colors">お問い合わせ</a>
      </div>
    </div>
  </section>

  <!-- 紹介文 -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-stone-700 leading-relaxed text-lg">
        <strong>DISCOVER HIDA</strong>は、雄大な山々と豊かな自然環境に恵まれた飛騨地方の魅力を余すところなくご紹介します。飛騨地方は、高山、白川郷、古川など、独自の伝統と文化を持つ町や村でも知られています。少人数制のガイド付きツアーでは、日本の田園地帯に隠された魅力的なスポットをじっくりと巡り、一生忘れられない思い出を作ることができます。
      </p>
    </div>
  </section>

  <!-- 区切り線 -->
  <div class="border-t border-stone-200 mx-4 md:mx-20"></div>

  <!-- 特徴セクション -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-xs tracking-[0.4em] uppercase text-stone-400 text-center mb-12">Why Discovery Hida</h2>
      <div class="grid md:grid-cols-3 gap-12">
        {[
          { title: feature1_title, body: feature1_body },
          { title: feature2_title, body: feature2_body },
          { title: feature3_title, body: feature3_body },
        ].map(f => (
          <div class="text-center">
            <h3 class="text-lg font-bold mb-4">{f.title}</h3>
            <p class="text-stone-500 leading-relaxed text-sm">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 区切り線 -->
  <div class="border-t border-stone-200 mx-4 md:mx-20"></div>

  <!-- ツアーラインナップ -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="bg-stone-900 text-white text-center py-4 mb-12">
        <h2 class="text-lg font-bold tracking-widest uppercase">ツアーラインナップ</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {tours.map(t => (
          <div class="group">
            <div class="aspect-video bg-stone-100 mb-4 overflow-hidden flex items-center justify-center">
              {t.thumbnail
                ? <img src={t.thumbnail} alt={t.title} class="w-full h-full object-cover" />
                : <span class="text-stone-300 text-xs">写真準備中</span>
              }
            </div>
            <h3 class="text-lg font-bold mb-3">{t.title}</h3>
            <p class="text-stone-500 text-sm leading-relaxed mb-4">{t.summary}</p>
            <a href={`/tours/${t.slug}`} class="inline-block border border-stone-800 text-stone-800 px-6 py-2 text-sm font-semibold hover:bg-stone-800 hover:text-white transition-colors">詳細はこちら</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- お客様の声 -->
  {testimonial_body && (
    <section class="py-16 px-4 bg-stone-50">
      <div class="max-w-6xl mx-auto">
        <div class="bg-stone-900 text-white text-center py-4 mb-12">
          <h2 class="text-lg font-bold tracking-widest uppercase">お客様の声</h2>
        </div>
        <div class="max-w-3xl mx-auto">
          <blockquote class="border border-stone-200 bg-white p-8 text-stone-600 leading-relaxed text-sm italic">
            {testimonial_body}
          </blockquote>
          <div class="mt-4 pl-2">
            <p class="font-bold text-stone-800">{testimonial_name}</p>
            <p class="text-stone-500 text-sm">{testimonial_title}</p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- 問い合わせCTA -->
  <section class="bg-stone-900 text-white py-20 px-4 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">Ready to Discover Hida?</h2>
      <p class="text-stone-400 mb-8">少人数制のツアーで、飛騨の本物に出会ってください。</p>
      <a href="/contact" class="bg-white text-stone-900 px-8 py-3 font-semibold hover:bg-stone-200 transition-colors">お問い合わせ</a>
    </div>
  </section>
</Layout>
