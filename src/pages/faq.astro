---
import Layout from '../layouts/Layout.astro';

const raw = await import('../content/pages/faq.md?raw');
const lines = raw.default.split('\n');
let fm: string[] = []; let s = false; let open = false;
for (const l of lines) {
  if (l.trim() === '---') { if (!s) { s = true; open = true; continue; } if (open) { open = false; continue; } }
  if (open) fm.push(l);
}

const get = (k: string) => { const r = fm.find(l => l.startsWith(k+':')); return r ? r.slice(k.length+1).trim().replace(/^"(.*)"$/,'$1') : ''; };
const title = get('title') || 'FAQ';
const subtitle = get('subtitle') || 'よくあるご質問';

// Parse FAQ list supporting both inline and block scalar (|) answers
const faqs: { question: string; answer: string }[] = [];
const faqsIdx = fm.findIndex(l => l.startsWith('faqs:'));
if (faqsIdx >= 0) {
  let i = faqsIdx + 1;
  while (i < fm.length) {
    if (fm[i].startsWith('  - question:')) {
      const question = fm[i].replace(/^\s+-\s+question:\s+/, '').replace(/^"(.*)"$/, '$1');
      let answer = '';
      if (i + 1 < fm.length) {
        const answerLine = fm[i + 1];
        if (answerLine.trim() === 'answer: |' || answerLine.trim().startsWith('answer: |')) {
          // Block scalar: collect indented lines
          let j = i + 2;
          const parts: string[] = [];
          while (j < fm.length && (fm[j].length === 0 || fm[j].startsWith('    '))) {
            parts.push(fm[j].trim());
            j++;
          }
          answer = parts.join('\n').trim();
          i = j;
        } else if (answerLine.trim().startsWith('answer:')) {
          answer = answerLine.replace(/^\s+answer:\s+/, '').replace(/^"(.*)"$/, '$1');
          i += 2;
        } else {
          i++;
        }
      } else {
        i++;
      }
      faqs.push({ question, answer });
    } else {
      i++;
    }
  }
}
---

<Layout title={title} description={`${title} — Discovery Hida`}>
  <section class="bg-stone-900 text-white py-24 px-4 text-center">
    <h1 class="text-5xl md:text-6xl font-bold tracking-tight">{title}</h1>
    <p class="mt-4 text-stone-400 text-sm tracking-widest">{subtitle}</p>
  </section>

  <section class="py-20 px-4">
    <div class="max-w-3xl mx-auto divide-y divide-stone-200">
      {faqs.map(faq => (
        <details class="group py-6 cursor-pointer">
          <summary class="flex justify-between items-center font-semibold text-stone-800 list-none">
            {faq.question}
            <span class="ml-4 flex-shrink-0 text-stone-400 group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="mt-4 text-stone-600 leading-relaxed text-sm whitespace-pre-line">{faq.answer}</div>
        </details>
      ))}
    </div>
  </section>

  <section class="bg-stone-50 py-16 px-4 text-center">
    <p class="text-stone-600 mb-6">他にご質問はありますか？</p>
    <a href="/contact" class="bg-stone-900 text-white px-8 py-3 font-semibold hover:bg-stone-700 transition-colors">お問い合わせ</a>
  </section>
</Layout>
