---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const tourFiles = import.meta.glob('../../content/tours/*.md', { eager: true, query: '?raw', import: 'default' });

  function parseTour(raw: string) {
    const ls = raw.split('\n');
    let fm: string[] = []; let body = ''; let s = false; let open = false; let bodyStarted = false;
    for (const l of ls) {
      if (l.trim() === '---') {
        if (!s) { s = true; open = true; continue; }
        if (open) { open = false; bodyStarted = true; continue; }
      }
      if (open) fm.push(l);
      else if (bodyStarted) body += l + '\n';
    }
    const get = (k: string) => { const r = fm.find(l => l.startsWith(k+':')); return r ? r.slice(k.length+1).trim().replace(/^"(.*)"$/,'$1') : ''; };
    const getBlock = (key: string) => {
      const idx = fm.findIndex(l => l.startsWith(key + ': |') || l.trim() === key + ': |');
      if (idx < 0) return '';
      let result = '';
      for (let i = idx + 1; i < fm.length; i++) {
        const l = fm[i];
        if (l.length > 0 && l[0] !== ' ') break;
        result += l.trim() + '\n';
      }
      return result.trim();
    };
    const getList = (key: string) => {
      const idx = fm.findIndex(l => l.startsWith(key + ':'));
      if (idx < 0) return [];
      const items: string[] = [];
      for (let i = idx + 1; i < fm.length; i++) {
        const l = fm[i];
        if (!l.startsWith('  -')) break;
        items.push(l.replace(/^\s+-\s+/, '').replace(/^"(.*)"$/, '$1'));
      }
      return items;
    };
    return {
      title: get('title'), thumbnail: get('thumbnail'), duration: get('duration'),
      season: get('season'),
      price: get('price'), min_guests: get('min_guests'), max_guests: get('max_guests'),
      meeting_point: get('meeting_point'), summary: get('summary'),
      body: getBlock('body') || body.trim(),
      what_to_bring: getList('what_to_bring'),
    };
  }

  return Object.entries(tourFiles).map(([path, raw]) => {
    const slug = path.split('/').pop()!.replace('.md', '');
    return { params: { slug }, props: parseTour(raw as string) };
  });
}

const { title, thumbnail, duration, season, price, min_guests, max_guests, meeting_point, summary, body, what_to_bring } = Astro.props;

function renderBody(md: string): string {
  const lines = md.split('\n');
  let html = '';
  let inList = false;
  let inTable = false;

  for (let i = 0; i < lines.length; i++) {
    const l = lines[i];

    if (l.startsWith('### ')) {
      if (inList) { html += '</ul>'; inList = false; }
      if (inTable) { html += '</tbody></table>'; inTable = false; }
      html += `<h3 class="text-lg font-bold mt-6 mb-2">${l.slice(4)}</h3>`;
    } else if (l.startsWith('## ')) {
      if (inList) { html += '</ul>'; inList = false; }
      if (inTable) { html += '</tbody></table>'; inTable = false; }
      html += `<h2 class="text-xl font-bold mt-8 mb-3 border-b border-stone-200 pb-2">${l.slice(3)}</h2>`;
    } else if (l.startsWith('---')) {
      if (inList) { html += '</ul>'; inList = false; }
      if (inTable) { html += '</tbody></table>'; inTable = false; }
      html += '<hr class="my-6 border-stone-200">';
    } else if (l.startsWith('|')) {
      if (inList) { html += '</ul>'; inList = false; }
      if (l.includes('---')) continue;
      const cells = l.split('|').filter((_, i2, a) => i2 > 0 && i2 < a.length - 1).map(c => c.trim());
      if (!inTable) {
        html += '<table class="w-full text-sm mb-4 border-collapse"><tbody>';
        inTable = true;
      }
      const isHeader = lines[i + 1]?.includes('---');
      const tag = isHeader ? 'th' : 'td';
      const cls = isHeader ? 'font-bold bg-stone-100 text-left px-3 py-2 border border-stone-200' : 'px-3 py-2 border border-stone-200 text-stone-600';
      html += '<tr>' + cells.map(c => `<${tag} class="${cls}">${c}</${tag}>`).join('') + '</tr>';
    } else if (l.startsWith('- ') || l.startsWith('* ')) {
      if (inTable) { html += '</tbody></table>'; inTable = false; }
      if (!inList) { html += '<ul class="list-disc ml-5 mb-4 space-y-1">'; inList = true; }
      html += `<li class="text-stone-600">${l.slice(2)}</li>`;
    } else if (l.startsWith('**') && l.endsWith('**')) {
      if (inList) { html += '</ul>'; inList = false; }
      if (inTable) { html += '</tbody></table>'; inTable = false; }
      html += `<p class="font-bold mt-4 mb-1 text-stone-800">${l.slice(2, -2)}</p>`;
    } else if (l.trim() === '') {
      if (inList) { html += '</ul>'; inList = false; }
      if (inTable) { html += '</tbody></table>'; inTable = false; }
    } else {
      if (inList) { html += '</ul>'; inList = false; }
      if (inTable) { html += '</tbody></table>'; inTable = false; }
      const formatted = l.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      html += `<p class="mb-3 text-stone-600 leading-relaxed">${formatted}</p>`;
    }
  }
  if (inList) html += '</ul>';
  if (inTable) html += '</tbody></table>';
  return html;
}
---

<Layout title={title} description={summary}>
  <section class="bg-stone-900 text-white py-24 px-4 text-center">
    <p class="text-xs tracking-[0.4em] uppercase text-stone-400 mb-4">Tours</p>
    <h1 class="text-4xl md:text-5xl font-bold">{title}</h1>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Tour image -->
      {thumbnail && (
        <div class="aspect-video bg-stone-100 mb-12 overflow-hidden">
          <img src={thumbnail} alt={title} class="w-full h-full object-cover" />
        </div>
      )}

      <div class="grid md:grid-cols-3 gap-12">
        <!-- Main content -->
        <div class="md:col-span-2">
          <p class="text-lg text-stone-600 leading-relaxed mb-8">{summary}</p>
          <div set:html={renderBody(body)} />
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="border border-stone-200 p-6">
            <h3 class="text-xs tracking-[0.3em] uppercase text-stone-400 mb-4">Tour Info</h3>
            <dl class="space-y-3 text-sm">
              <div>
                <dt class="text-stone-400 text-xs">料金</dt>
                <dd class="font-bold text-lg">{price}</dd>
              </div>
              <div>
                <dt class="text-stone-400 text-xs">所要時間</dt>
                <dd class="font-semibold">{duration}</dd>
              </div>
              {season && (
                <div>
                  <dt class="text-stone-400 text-xs">シーズン</dt>
                  <dd class="font-semibold">{season}</dd>
                </div>
              )}
              <div>
                <dt class="text-stone-400 text-xs">参加人数</dt>
                <dd class="font-semibold">{min_guests}〜{max_guests}名</dd>
              </div>
              <div>
                <dt class="text-stone-400 text-xs">集合場所</dt>
                <dd class="font-semibold">{meeting_point}</dd>
              </div>
            </dl>
          </div>

          {what_to_bring.length > 0 && (
            <div class="border border-stone-200 p-6">
              <h3 class="text-xs tracking-[0.3em] uppercase text-stone-400 mb-4">持ち物</h3>
              <ul class="space-y-2">
                {what_to_bring.map(item => (
                  <li class="flex items-start gap-2 text-sm text-stone-600">
                    <span class="mt-1.5 w-1 h-1 bg-stone-400 rounded-full flex-shrink-0"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <a href="/contact" class="block w-full bg-stone-900 text-white text-center py-4 font-semibold tracking-wide hover:bg-stone-700 transition-colors">
            お問い合わせ・お申し込み
          </a>
          <a href="/tours" class="block w-full border border-stone-300 text-stone-600 text-center py-4 text-sm tracking-wide hover:border-stone-800 hover:text-stone-800 transition-colors">
            ← ツアー一覧に戻る
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
