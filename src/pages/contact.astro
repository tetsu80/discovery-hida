---
import Layout from '../layouts/Layout.astro';

const raw = await import('../content/pages/contact.md?raw');
const lines = raw.default.split('\n');
let fm: string[] = []; let s = false; let open = false;
for (const l of lines) {
  if (l.trim() === '---') { if (!s) { s = true; open = true; continue; } if (open) { open = false; continue; } }
  if (open) fm.push(l);
}
const get = (k: string) => { const r = fm.find(l => l.startsWith(k+':')); return r ? r.slice(k.length+1).trim().replace(/^"(.*)"$/,'$1') : ''; };

const email = get('email');
const form_access_key = get('form_access_key');
const intro_ja = get('intro_ja');
const intro_en = get('intro_en');
---

<Layout title="Contact" description="お問い合わせ — Discovery Hida">
  <!-- ヒーローバナー -->
  <section class="bg-stone-900 text-white py-24 px-4 text-center">
    <h1 class="text-5xl md:text-6xl font-bold tracking-tight">CONTACT US</h1>
    <p class="mt-4 text-stone-400 text-sm tracking-widest">お問い合わせ</p>
  </section>

  <!-- メインコンテンツ -->
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-start">

      <!-- 左：連絡先情報 -->
      <div>
        <p class="text-stone-600 leading-relaxed mb-2 text-sm">{intro_en}</p>
        <p class="text-stone-500 leading-relaxed mb-10 text-sm">{intro_ja}</p>

        <h2 class="text-sm font-bold tracking-widest uppercase text-stone-800 mb-4">Contact Information</h2>
        <div class="space-y-3">
          <div>
            <p class="text-xs text-stone-400 uppercase tracking-widest mb-1">Email</p>
            <a href={`mailto:${email}`} class="text-stone-700 font-semibold hover:underline">{email}</a>
          </div>
        </div>
      </div>

      <!-- 右：お問い合わせフォーム -->
      <div>
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="space-y-4"
        >
          <input type="hidden" name="access_key" value={form_access_key} />
          <input type="hidden" name="subject" value="Discovery Hida — お問い合わせ" />
          <input type="hidden" name="redirect" value="/contact?sent=true" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

          <div class="grid sm:grid-cols-2 gap-4">
            <input
              type="text"
              name="name"
              placeholder="Name / お名前"
              required
              class="w-full border border-stone-300 px-4 py-3 text-sm placeholder-stone-400 focus:outline-none focus:border-stone-800"
            />
            <input
              type="email"
              name="email"
              placeholder="Email / メール"
              required
              class="w-full border border-stone-300 px-4 py-3 text-sm placeholder-stone-400 focus:outline-none focus:border-stone-800"
            />
          </div>

          <input
            type="tel"
            name="phone"
            placeholder="Phone / 電話 (optional)"
            class="w-full border border-stone-300 px-4 py-3 text-sm placeholder-stone-400 focus:outline-none focus:border-stone-800"
          />

          <input
            type="text"
            name="subject_line"
            placeholder="Subject / 主題"
            class="w-full border border-stone-300 px-4 py-3 text-sm placeholder-stone-400 focus:outline-none focus:border-stone-800"
          />

          <textarea
            name="message"
            placeholder="Message / メッセージ"
            required
            rows="6"
            class="w-full border border-stone-300 px-4 py-3 text-sm placeholder-stone-400 focus:outline-none focus:border-stone-800 resize-none"
          ></textarea>

          <button
            type="submit"
            class="w-full bg-stone-900 text-white py-4 font-semibold tracking-wide hover:bg-stone-700 transition-colors"
          >
            Send / 送信
          </button>
        </form>

        <!-- 送信完了メッセージ -->
        <div id="success-msg" class="hidden mt-6 bg-stone-50 border border-stone-200 p-6 text-center">
          <p class="font-semibold text-stone-800 mb-1">Thank you!</p>
          <p class="text-stone-500 text-sm">We will get back to you within 48 hours.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQへの誘導 -->
  <section class="bg-stone-50 py-16 px-4 text-center">
    <p class="text-stone-500 text-sm mb-2">よくある質問もご参照ください。</p>
    <a href="/faq" class="text-stone-800 font-semibold underline hover:no-underline text-sm">FAQ ページを見る →</a>
  </section>
</Layout>

<script>
  // Show success banner if redirected back with ?sent=true
  if (window.location.search.includes('sent=true')) {
    const msg = document.getElementById('success-msg');
    if (msg) msg.classList.remove('hidden');
  }
</script>
