---
import Layout from '../layouts/Layout.astro';

const raw = await import('../content/pages/contact.md?raw');
const lines = raw.default.split('\n');
let fm: string[] = []; let s = false; let open = false;
for (const l of lines) {
  if (l.trim() === '---') { if (!s) { s = true; open = true; continue; } if (open) { open = false; continue; } }
  if (open) fm.push(l);
}
const get = (k: string) => { const r = fm.find(l => l.startsWith(k+':')); return r ? r.slice(k.length+1).trim().replace(/^"(.*)"$/,'$1') : ''; };

const email = get('email');
const line_url = get('line_url');
const intro = get('intro');
---

<Layout title="Contact" description="お問い合わせ — Discovery Hida">
  <section class="bg-stone-900 text-white py-24 px-4 text-center">
    <h1 class="text-5xl md:text-6xl font-bold tracking-tight">CONTACT</h1>
    <p class="mt-4 text-stone-400 text-sm tracking-widest">お問い合わせ</p>
  </section>

  <section class="py-20 px-4">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-stone-600 leading-relaxed mb-12">{intro}</p>

      <div class="grid sm:grid-cols-2 gap-6 mb-16">
        <!-- Email -->
        <a href={`mailto:${email}`} class="group border border-stone-200 p-8 hover:border-stone-800 transition-colors flex flex-col items-center gap-4">
          <svg class="w-8 h-8 text-stone-400 group-hover:text-stone-800 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <div>
            <p class="text-xs tracking-widest uppercase text-stone-400 mb-1">Email</p>
            <p class="font-semibold text-sm break-all">{email}</p>
          </div>
        </a>

        <!-- LINE -->
        {line_url ? (
          <a href={line_url} target="_blank" rel="noopener" class="group border border-stone-200 p-8 hover:border-stone-800 transition-colors flex flex-col items-center gap-4">
            <svg class="w-8 h-8 text-stone-400 group-hover:text-stone-800 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.105.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
            </svg>
            <div>
              <p class="text-xs tracking-widest uppercase text-stone-400 mb-1">LINE</p>
              <p class="font-semibold text-sm">LINEで問い合わせる</p>
            </div>
          </a>
        ) : (
          <div class="border border-dashed border-stone-200 p-8 flex flex-col items-center gap-4 opacity-50">
            <p class="text-xs tracking-widest uppercase text-stone-400">LINE</p>
            <p class="text-sm text-stone-400">準備中</p>
          </div>
        )}
      </div>

      <div class="bg-stone-50 p-8 text-left">
        <h3 class="text-xs tracking-[0.3em] uppercase text-stone-400 mb-4">キャンセルポリシー</h3>
        <ul class="text-sm text-stone-600 space-y-2">
          <li>・7日前まで：キャンセル料なし</li>
          <li>・3日前〜前日：ツアー料金の50%</li>
          <li>・当日：ツアー料金の100%</li>
          <li>・荒天による中止の場合：全額返金</li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
